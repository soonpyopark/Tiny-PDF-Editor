{
  "name": "tiny-pdf-editor",
  "version": "1.0.2",
  "private": true,
  "description": "Tiny PDF Editor desktop app",
  "scripts": {
    "sync-version": "node scripts/sync-version.mjs",
    "build": "node scripts/sync-version.mjs && node scripts/build-dist.mjs",
    "build:dist:exe": "node scripts/sync-version.mjs && node scripts/build-dist.mjs",
    "build:dist:exe:update": "node scripts/sync-version.mjs && node scripts/build-dist.mjs --update"
  }
}
