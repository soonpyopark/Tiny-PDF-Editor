<?xml version="1.0" encoding="UTF-8"?>
<!--
  Tiny PDF Editor MSI (per-user, HKCU PDF association).
  Build: npm run build:msi
  Requires WiX CLI 7+ (winget install WiXToolset.WiXCLI) and: wix eula accept wix7

  Payload is staged to msi/Tiny PDF Editor/ before linking (same folder as this .wxs).
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Tiny PDF Editor"
           Manufacturer="Tiny PDF Editor"
           Version="$(var.ProductVersion)"
           ProductCode="$(var.ProductCode)"
           UpgradeCode="A3C7E1F4-9B2D-4E6A-8C0F-1D5E7B9A2C4E"
           Scope="perUser"
           Codepage="65001"
           Compressed="yes">

    <!--
      Existing install (same UpgradeCode) is fully removed before new files
      are laid down (afterInstallValidate). Reinstalling the same app version
      also replaces the previous MSI (AllowSameVersionUpgrades).
    -->
    <MajorUpgrade
      DowngradeErrorMessage="더 새로운 버전의 Tiny PDF Editor가 이미 설치되어 있습니다."
      AllowSameVersionUpgrades="yes"
      Schedule="afterInstallValidate"
      MigrateFeatures="yes" />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="ARPHELPLINK" Value="https://note4all.tistory.com" />

    <ui:WixUI Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <Feature Id="MainFeature" Title="Tiny PDF Editor" Level="1">
      <Files Include="Tiny PDF Editor/**" />
      <ComponentRef Id="PdfFileAssociation" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="Tiny PDF Editor" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Tiny PDF Editor" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <Component Id="PdfFileAssociation" Directory="INSTALLFOLDER" Guid="F2A8C4D6-1E3B-4F5A-9C7D-8E0B2A4C6D8E">
      <RegistryKey Root="HKCU" Key="Software\Classes\Applications\Tiny PDF Editor.exe">
        <RegistryValue Type="string" Value="Tiny PDF Editor" />
        <RegistryValue Name="FriendlyAppName" Type="string" Value="Tiny PDF Editor" />
        <RegistryValue Name="AppUserModelID" Type="string" Value="TinyPDFEditor.TinyPDFEditor.1" />
      </RegistryKey>

      <RegistryKey Root="HKCU" Key="Software\Classes\Applications\Tiny PDF Editor.exe\shell\open\command">
        <RegistryValue Type="string" Value="&quot;[INSTALLFOLDER]Tiny PDF Editor.exe&quot; &quot;%1&quot;" KeyPath="yes" />
      </RegistryKey>

      <RegistryKey Root="HKCU" Key="Software\Classes\Applications\Tiny PDF Editor.exe\SupportedTypes\.pdf">
        <RegistryValue Type="string" Value="" />
      </RegistryKey>

      <RegistryKey Root="HKCU" Key="Software\TinyPDFEditor\Capabilities">
        <RegistryValue Name="ApplicationName" Type="string" Value="Tiny PDF Editor" />
        <RegistryValue Name="ApplicationDescription" Type="string" Value="Tiny PDF Editor PDF editor" />
        <RegistryValue Name="FileAssociations" Type="string" Value=".pdf" />
      </RegistryKey>

      <RegistryKey Root="HKCU" Key="Software\RegisteredApplications">
        <RegistryValue Name="Tiny PDF Editor" Type="string" Value="Software\TinyPDFEditor\Capabilities" />
      </RegistryKey>

      <RegistryKey Root="HKCU" Key="Software\Classes\TinyPDFEditor.pdf">
        <RegistryValue Type="string" Value="Tiny PDF Editor" />
      </RegistryKey>

      <RegistryKey Root="HKCU" Key="Software\Classes\TinyPDFEditor.pdf\DefaultIcon">
        <RegistryValue Type="string" Value="[INSTALLFOLDER]pdf_file_icon.ico,0" />
      </RegistryKey>

      <RegistryKey Root="HKCU" Key="Software\Classes\Applications\Tiny PDF Editor.exe\DefaultIcon">
        <RegistryValue Type="string" Value="[INSTALLFOLDER]pdf_file_icon.ico,0" />
      </RegistryKey>

      <RegistryKey Root="HKCU" Key="Software\Classes\TinyPDFEditor.pdf\shell\open\command">
        <RegistryValue Type="string" Value="&quot;[INSTALLFOLDER]Tiny PDF Editor.exe&quot; &quot;%1&quot;" />
      </RegistryKey>

      <RegistryKey Root="HKCU" Key="Software\Classes\.pdf\OpenWithProgids">
        <RegistryValue Name="TinyPDFEditor.pdf" Type="string" Value="" />
      </RegistryKey>
    </Component>

    <Component Id="StartMenuShortcut" Directory="ApplicationProgramsFolder" Guid="C5D9E1F3-7A2B-4C6D-8E0F-1A3B5C7D9E1F">
      <Shortcut Id="StartMenuShortcut"
                Name="Tiny PDF Editor"
                Description="Tiny PDF Editor"
                Target="[INSTALLFOLDER]Tiny PDF Editor.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKCU"
                     Key="Software\Tiny PDF Editor\Tiny PDF Editor"
                     Name="installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
    </Component>

    <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="D7E3F5A9-4C6B-4D8E-9F0A-2B4C6D8E0F12">
      <Shortcut Id="DesktopShortcut"
                Name="Tiny PDF Editor"
                Description="Tiny PDF Editor"
                Target="[INSTALLFOLDER]Tiny PDF Editor.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKCU"
                     Key="Software\Tiny PDF Editor\Tiny PDF Editor"
                     Name="desktop_shortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>
  </Package>
</Wix>
